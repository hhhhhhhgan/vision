<Window x:Class="VisionFlow.Views.ToolDialogs.ThresholdDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:halcon="clr-namespace:HalconDotNet;assembly=halcondotnet"
        Title="阈值分割" Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#1A2634">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#243447" CornerRadius="8" Margin="0,0,10,0" Padding="12">
            <StackPanel>
                <TextBlock Text="🔲 阈值分割" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="阈值模式" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <ComboBox x:Name="ModeCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,10">
                    <ComboBoxItem Content="max — 自动阈值"/>
                    <ComboBoxItem Content="min — 暗区"/>
                    <ComboBoxItem Content="range — 范围阈值"/>
                </ComboBox>

                <TextBlock Text="最小阈值" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="MinThreshTextBox" Text="128" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="最大阈值" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <TextBox x:Name="MaxThreshTextBox" Text="255" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>

                <TextBlock x:Name="InfoTextBlock" Foreground="#10B981" FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="8" BorderBrush="#3D5A73" BorderThickness="1">
                <halcon:HWindowControl x:Name="HWindow" Background="#0F1923"/>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
                <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>