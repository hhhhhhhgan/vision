<Window Base="{x:Type local:ToolDialogBase}" x:Class="VisionFlow.Views.ToolDialogs.ImageProcessingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ha="http://schemas.mvtec.com/halcondotnet"
        Title="图像处理" Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#1A2634">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#243447" CornerRadius="8" Margin="0,0,10,0" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="ToolNameBlock" Text="图像处理" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ToolDescBlock" Text="" Foreground="#8BA4C7" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Separator Background="#3D5A73" Margin="0,0,0,12"/>

                    <TextBlock Text="参数配置" Foreground="#8BA4C7" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <!-- 动态参数区域 -->
                    <StackPanel x:Name="ParamPanel">
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="8" BorderBrush="#3D5A73" BorderThickness="1">
                <ha:HWindowControlWPF x:Name="HWindow" Background="#0F1923"/>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
                <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>