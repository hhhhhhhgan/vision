<Window x:Class="VisionFlow.Views.ToolDialogs.CSharpScriptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:VisionFlow.Views.ToolDialogs"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="C# 脚本" Height="680" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="C# 脚本" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="  — 输入变量直接可用，赋值给 Result" Foreground="#888" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 接口说明 -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📥 输入变量" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="Image  → HImage?" Foreground="#4FC3F7" FontSize="10" Margin="0,4,0,0"/>
                    <TextBlock Text="Region → HRegion?" Foreground="#4FC3F7" FontSize="10"/>
                    <TextBlock Text="Value  → double?" Foreground="#4FC3F7" FontSize="10"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="🔧 可用类型/成员" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="HImage.Width/Height, .DispImage()" Foreground="#ACA899" FontSize="10" Margin="0,4,0,0"/>
                    <TextBlock Text="HRegion.Area, .Connection()" Foreground="#ACA899" FontSize="10"/>
                    <TextBlock Text="Math.*, Convert.*" Foreground="#ACA899" FontSize="10"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="📤 输出" Foreground="#AAA" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="Result = ..." Foreground="#FF8C00" FontSize="10" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="（必须赋值）" Foreground="#555" FontSize="10"/>
                    <TextBlock Text="按 Ctrl+Space 触发补齐" Foreground="#555" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- AvalonEdit 代码编辑器 -->
        <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4">
            <avalonedit:TextEditor x:Name="CodeEditor"
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   Background="#1E1E1E"
                                   Foreground="#D4D4D4"
                                   LineNumbersForeground="#858585"
                                   Padding="5"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"/>
        </Border>

        <!-- 状态栏 -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusTextBlock" Text="就绪  •  按 Ctrl+Space 触发自动补齐" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Ctrl+Space 补齐  •  Tab 插入选定  •  Enter 确认" Foreground="#555" FontSize="10" VerticalAlignment="Center"/>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="格式化" Click="FormatButton_Click" Width="80" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>