<Window x:Class="VisionFlow.Views.ToolDialogs.LocatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:halcon="clr-namespace:HalconDotNet.WPF;assembly=halcondotnet"
        Title="定位器" Height="700" Width="950"
        WindowStartupLocation="CenterOwner"
        Background="#1A2634">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧参数 -->
        <Border Grid.Column="0" Background="#243447" CornerRadius="8" Margin="0,0,10,0" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🎯 定位器" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- 定位模式 -->
                    <TextBlock Text="定位模式" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LocateModeCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" SelectionChanged="LocateModeCombo_SelectionChanged">
                        <ComboBoxItem Content="blob_center — Blob中心"/>
                        <ComboBoxItem Content="edge_pair — 边缘对"/>
                        <ComboBoxItem Content="template — 模板匹配"/>
                    </ComboBox>

                    <Separator Background="#3D5A73" Margin="0,12"/>

                    <!-- ROI -->
                    <TextBlock Text="ROI 区域" Foreground="#8BA4C7" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,4">
                            <TextBlock Text="Row1" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="ROIRow1TextBox" Text="50" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,4">
                            <TextBlock Text="Col1" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="ROICol1TextBox" Text="50" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Row2" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="ROIRow2TextBox" Text="350" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="Col2" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="ROICol2TextBox" Text="350" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#3D5A73" Margin="0,12"/>

                    <!-- 偏移补正 -->
                    <TextBlock Text="偏移补正" Foreground="#8BA4C7" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,4">
                            <TextBlock Text="Offset X" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="OffsetXTextBox" Text="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,4">
                            <TextBlock Text="Offset Y" Foreground="#5A7390" FontSize="10"/>
                            <TextBox x:Name="OffsetYTextBox" Text="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="Offset Angle (°)" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="OffsetAngleTextBox" Text="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                    </StackPanel>

                    <CheckBox x:Name="FollowRefCheckBox" Content="跟随参考点模式" IsChecked="False" Foreground="#8BA4C7" Margin="0,4,0,0"/>

                    <CheckBox x:Name="FollowOffsetCheckBox" Content="其他工具跟随偏移" IsChecked="False" Foreground="#8BA4C7" Margin="0,6,0,0"/>

                    <Separator Background="#3D5A73" Margin="0,12"/>

                    <!-- Blob参数 -->
                    <TextBlock Text="Blob 参数" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="Threshold" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="ThresholdTextBox" Text="128" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="Min Area" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="MinAreaTextBox" Text="100" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="5,4"/>
                    </StackPanel>

                    <Button Content="应用预览" Click="ApplyButton_Click" Padding="8,6" Background="#0D6EFD" Foreground="White" BorderThickness="0" Margin="0,8,0,0" Cursor="Hand"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧图像窗口 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="8" BorderBrush="#3D5A73" BorderThickness="1" ClipToBounds="True">
                <halcon:HWindowControl x:Name="HWindow" Background="#0F1923"/>
            </Border>

            <TextBlock x:Name="InfoTextBlock" Grid.Row="1" Margin="0,8,0,0" Foreground="#8BA4C7" FontSize="11"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
                <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>