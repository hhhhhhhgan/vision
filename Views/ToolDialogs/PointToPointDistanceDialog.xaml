<Window Base="{x:Type local:ToolDialogBase}" x:Class="VisionFlow.Views.ToolDialogs.PointToPointDistanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点点距离" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="点点距离" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="点1" Foreground="#AAA" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="点2" Foreground="#AAA" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="Row1TextBox" Text="0" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555" Margin="0,0,10,5"/>
            <TextBox Grid.Row="0" Grid.Column="2" x:Name="Col1TextBox" Text="0" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555" Margin="0,0,0,5"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="Row2TextBox" Text="0" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555" Margin="0,0,10,0"/>
            <TextBox Grid.Row="1" Grid.Column="2" x:Name="Col2TextBox" Text="0" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="(Row, Col)" Foreground="#555" VerticalAlignment="Center" Margin="5,0,0,5"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="(Row, Col)" Foreground="#555" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="距离:" Foreground="#AAA" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="DistanceTextBlock" Text="-" Foreground="#00D4FF" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="像素" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>

        <Button Grid.Row="4" Content="关闭" Click="CloseButton_Click" Width="80" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0" HorizontalAlignment="Right"/>
    </Grid>
</Window>