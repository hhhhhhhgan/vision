<Window x:Class="VisionFlow.Views.ToolDialogs.StressTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="压力测试" Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚡ 连续运行压力测试" FontSize="16" FontWeight="Bold"
                   Foreground="#F9FAFB" Margin="0,0,0,16"/>

        <!-- 运行次数 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="运行次数:" Foreground="#9CA3AF" VerticalAlignment="Center"/>
            <TextBox x:Name="RunCountBox" Grid.Column="1" Text="999" FontSize="13"
                     Background="#1F2937" Foreground="#F9FAFB" BorderBrush="#374151"
                     Padding="8,6"/>
        </Grid>

        <!-- 间隔时间 -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="间隔 (ms):" Foreground="#9CA3AF" VerticalAlignment="Center"/>
            <TextBox x:Name="DelayBox" Grid.Column="1" Text="0" FontSize="13"
                     Background="#1F2937" Foreground="#F9FAFB" BorderBrush="#374151"
                     Padding="8,6"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="进度:" Foreground="#9CA3AF" VerticalAlignment="Center"/>
            <ProgressBar x:Name="ProgressBar" Grid.Column="1" Height="8" Margin="0,0,8,0"
                         Background="#1F2937" Foreground="#3B82F6"/>
            <TextBlock x:Name="ProgressText" Grid.Column="2" Text="0/0" Foreground="#9CA3AF"
                       FontSize="11" VerticalAlignment="Center"/>
        </Grid>

        <!-- 统计 -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="SuccessCount" Text="✓ 0" Foreground="#10B981" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="成功" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="FailCount" Text="✗ 0" Foreground="#EF4444" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="失败" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock x:Name="ErrorCount" Text="⚠ 0" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="异常" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock x:Name="AvgTime" Text="0ms" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="平均耗时" Foreground="#6B7280" FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 错误列表 -->
        <ListBox x:Name="ErrorList" Grid.Row="5" Background="#1F2937" Foreground="#F9FAFB"
                 BorderBrush="#374151" FontSize="11" Margin="0,0,0,12"
                 Visibility="Collapsed"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartBtn" Content="▶ 开始测试" Width="100" Margin="0,0,8,0"
                    Click="StartBtn_Click"
                    Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="10,8" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="■ 停止" Width="80" Margin="0,0,8,0"
                    Click="CancelBtn_Click" IsEnabled="False"
                    Background="#374151" Foreground="#9CA3AF" BorderThickness="0" Padding="10,8" Cursor="Hand"/>
            <Button Content="关闭" Width="60" Click="CloseBtn_Click"
                    Background="#1F2937" Foreground="#9CA3AF" BorderThickness="0" Padding="10,8" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>