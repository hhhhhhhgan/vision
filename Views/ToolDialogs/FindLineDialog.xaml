<Window x:Class="VisionFlow.Views.ToolDialogs.FindLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:halcon="clr-namespace:HalconDotNet.WPF;assembly=HalconDotNet.WPF"
        Title="查找线" Height="700" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧参数面板 -->
        <Border Grid.Column="0" Background="#2D2D30" Margin="0,0,10,0" CornerRadius="4" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ROI 区域" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                    <TextBlock Text="Row1" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="ROIRow1TextBox" Text="100" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Col1" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="ROICol1TextBox" Text="100" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Row2" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="ROIRow2TextBox" Text="300" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Col2" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="ROICol2TextBox" Text="400" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <Separator Background="#555" Margin="0,10"/>

                    <TextBlock Text="边缘参数" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                    <TextBlock Text="Sigma (平滑)" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="SigmaTextBox" Text="1.0" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Edge Threshold" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="EdgeThresholdTextBox" Text="25" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Transition" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <ComboBox x:Name="TransitionComboBox" SelectedIndex="0" Background="#3E3E42" Foreground="White">
                        <ComboBoxItem Content="all"/>
                        <ComboBoxItem Content="positive"/>
                        <ComboBoxItem Content="negative"/>
                    </ComboBox>

                    <TextBlock Text="Select Points" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="SelectPointsTextBox" Text="15" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <TextBlock Text="Num Iterations" Foreground="#AAA" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="NumIterationsTextBox" Text="5" Padding="4" Background="#3E3E42" Foreground="White" BorderBrush="#555"/>

                    <Separator Background="#555" Margin="0,10"/>

                    <Button Content="应用参数" Click="ApplyButton_Click" Padding="10,6" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧 HALCON 窗口 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#3E3E42" BorderThickness="1">
                <halcon:HWindowControlWPF x:Name="HWindow" Background="Black"/>
            </Border>

            <TextBlock x:Name="InfoTextBlock" Grid.Row="1" Margin="0,8,0,0" Foreground="#AAA" FontSize="11"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>