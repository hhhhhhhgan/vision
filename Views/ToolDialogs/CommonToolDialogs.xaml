<Window x:Class="VisionFlow.Views.ToolDialogs.MorphologyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="形态学" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" Background="#1A2634" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="🔠 形态学操作" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="操作类型" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <ComboBox x:Name="OpCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,10">
                    <ComboBoxItem Content="dilation — 膨胀"/>
                    <ComboBoxItem Content="erosion — 腐蚀"/>
                    <ComboBoxItem Content="opening — 开运算"/>
                    <ComboBoxItem Content="closing — 闭运算"/>
                </ComboBox>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="结构元半径" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="RadiusTextBox" Text="3" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="迭代次数" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="IterTextBox" Text="1" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VisionFlow.Views.ToolDialogs.BlobAnalysisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blob分析" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" Background="#1A2634" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="📊 Blob分析" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <StackPanel>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="最小面积" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="MinAreaTextBox" Text="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="最大面积" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="MaxAreaTextBox" Text="999999" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="排序方式" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <ComboBox x:Name="SortCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8">
                    <ComboBoxItem Content="area — 按面积"/>
                    <ComboBoxItem Content="row — 按Row坐标"/>
                    <ComboBoxItem Content="column — 按Col坐标"/>
                </ComboBox>
                <TextBlock Text="取前N个 (0=全部)" Foreground="#5A7390" FontSize="10"/>
                <TextBox x:Name="TopNTextBox" Text="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VisionFlow.Views.ToolDialogs.CaliperMeasureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="卡尺测量" Height="380" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1A2634">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="📏 卡尺测量" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="测量参数" Foreground="#8BA4C7" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="卡尺半长" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="LengthText" Text="20" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="卡尺宽度" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="WidthText" Text="3" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                </Grid>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="Sigma" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="SigmaText" Text="1.0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="边缘阈值" Foreground="#5A7390" FontSize="10"/>
                        <TextBox x:Name="ThreshText" Text="25" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="💡 连接LineRow1/Col1/Row2/Col2到测量线的端点坐标" Foreground="#555" FontSize="10" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VisionFlow.Views.ToolDialogs.ImageSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存图像" Height="280" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1A2634" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="💾 保存图像" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="保存路径" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PathTextBox" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>
                    <Button Grid.Column="1" Content="浏览..." Click="BrowseButton_Click" Background="#3D5A73" Foreground="White" BorderThickness="0" Padding="8,4" Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Text="格式" Foreground="#8BA4C7" FontSize="10" Margin="0,10,0,4"/>
                <ComboBox x:Name="FormatCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4">
                    <ComboBoxItem Content="PNG"/>
                    <ComboBoxItem Content="JPEG"/>
                    <ComboBoxItem Content="BMP"/>
                    <ComboBoxItem Content="TIFF"/>
                </ComboBox>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VisionFlow.Views.ToolDialogs.GetGrayValueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="灰度提取" Height="200" Width="380"
        WindowStartupLocation="CenterOwner" Background="#1A2634" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="🖐 灰度提取" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <TextBlock Text="连接 Row 和 Col 坐标到图像上需要测量的点位置&#x0a;输出 GrayValue 为该点的灰度值" Foreground="#8BA4C7" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>