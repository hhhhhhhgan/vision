<Window Base="{x:Type local:ToolDialogBase}" x:Class="VisionFlow.Views.ToolDialogs.LineToLineDistanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="线线距离" Height="300" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="线线距离（两条线段的最短距离）" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="线1" Foreground="#AAA" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,2">
                <TextBlock Text="R1:" Foreground="#888" Width="30"/>
                <TextBox x:Name="R1TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
                <TextBlock Text="C1:" Foreground="#888" Width="30" Margin="10,0,0,0"/>
                <TextBox x:Name="C1TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="R2:" Foreground="#888" Width="30"/>
                <TextBox x:Name="R2TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
                <TextBlock Text="C2:" Foreground="#888" Width="30" Margin="10,0,0,0"/>
                <TextBox x:Name="C2TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="线2" Foreground="#AAA" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                <TextBlock Text="R1:" Foreground="#888" Width="30"/>
                <TextBox x:Name="R3TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
                <TextBlock Text="C1:" Foreground="#888" Width="30" Margin="10,0,0,0"/>
                <TextBox x:Name="C3TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="R2:" Foreground="#888" Width="30"/>
                <TextBox x:Name="R4TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
                <TextBlock Text="C2:" Foreground="#888" Width="30" Margin="10,0,0,0"/>
                <TextBox x:Name="C4TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="70"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="最短距离:" Foreground="#AAA" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="DistanceTextBlock" Text="-" Foreground="#00D4FF" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="像素" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>

        <Button Grid.Row="4" Content="关闭" Click="CloseButton_Click" Width="80" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0" HorizontalAlignment="Right"/>
    </Grid>
</Window>