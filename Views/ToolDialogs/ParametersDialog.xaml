<Window x:Class="VisionFlow.Views.ToolDialogs.ParametersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VisionFlow.Views.ToolDialogs"
        xmlns:models="clr-namespace:VisionFlow.Models"
        Title="流程参数配置" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <local:NodeSlotsConverter x:Key="NodeSlotsConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 输入参数标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📥 输入参数" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="（外部调用时传入）" Foreground="#666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ 新增输入" Click="AddInput_Click" Padding="12,5"
                    Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- 输入参数列表 -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                <ItemsControl x:Name="InputParamsList" ItemsSource="{Binding Parameters.Inputs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D30" CornerRadius="4" Margin="3,4" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 参数名称 -->
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="参数名称" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#1E1E1E" Foreground="White" BorderBrush="#555"
                                                 Padding="6,4" FontSize="13"/>
                                    </StackPanel>

                                    <!-- 数据类型 -->
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="数据类型" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{x:Static local:ParameterDataTypes.All}"
                                                  SelectedItem="{Binding DataType}"
                                                  Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"/>
                                    </StackPanel>

                                    <!-- 描述 -->
                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="描述" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#1E1E1E" Foreground="White" BorderBrush="#555"
                                                 Padding="6,4" FontSize="12"/>
                                    </StackPanel>

                                    <!-- 绑定节点 -->
                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                        <TextBlock Text="绑定节点" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="NodeCombo" ItemsSource="{Binding DataContext.Nodes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Node.Tool.Name"
                                                  SelectedValuePath="Node.Id"
                                                  SelectedValue="{Binding LinkedNodeId}"
                                                  Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"/>
                                    </StackPanel>

                                    <!-- 绑定槽 -->
                                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                        <TextBlock Text="绑定槽" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="SlotCombo" Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"
                                                  ItemsSource="{Binding LinkedNodeId, Converter={StaticResource NodeSlotsConverter}, ConverterParameter=input}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding LinkedSlotName}"/>
                                    </StackPanel>

                                    <!-- 删除按钮 -->
                                    <Button Grid.Column="5" Content="✕" Click="RemoveInput_Click" Tag="{Binding Id}"
                                            Background="Transparent" Foreground="#FF5252" BorderThickness="0"
                                            FontSize="16" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                            ToolTip="删除此参数"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 分隔线 -->
        <Rectangle Grid.Row="2" Height="1" Fill="#3E3E42" Margin="0,12"/>

        <!-- 输出参数标题 -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📤 输出参数" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="（执行完成后外部读取）" Foreground="#666" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ 新增输出" Click="AddOutput_Click" Padding="12,5"
                    Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- 输出参数列表 -->
        <Border Grid.Row="4" Background="#252526" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                <ItemsControl x:Name="OutputParamsList" ItemsSource="{Binding Parameters.Outputs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D30" CornerRadius="4" Margin="3,4" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="参数名称" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#1E1E1E" Foreground="White" BorderBrush="#555"
                                                 Padding="6,4" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="数据类型" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{x:Static local:ParameterDataTypes.All}"
                                                  SelectedItem="{Binding DataType}"
                                                  Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="描述" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#1E1E1E" Foreground="White" BorderBrush="#555"
                                                 Padding="6,4" FontSize="12"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                        <TextBlock Text="绑定节点" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox ItemsSource="{Binding DataContext.Nodes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Node.Tool.Name"
                                                  SelectedValuePath="Node.Id"
                                                  SelectedValue="{Binding LinkedNodeId}"
                                                  Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                        <TextBlock Text="绑定槽" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                        <ComboBox Background="#1E1E1E" Foreground="White" BorderBrush="#555" Padding="6,4"
                                                  ItemsSource="{Binding LinkedNodeId, Converter={StaticResource NodeSlotsConverter}, ConverterParameter=output}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding LinkedSlotName}"/>
                                    </StackPanel>

                                    <Button Grid.Column="5" Content="✕" Click="RemoveOutput_Click" Tag="{Binding Id}"
                                            Background="Transparent" Foreground="#FF5252" BorderThickness="0"
                                            FontSize="16" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                            ToolTip="删除此参数"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 底部状态/关闭 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="💡 参数名称和数据类型可自由定义，绑定节点后自动关联槽位"
                       Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="关闭" Click="CloseButton_Click" Width="80" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>