<Window x:Class="VisionFlow.Views.ToolDialogs.ImageRotateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:halcon="clr-namespace:HalconDotNet.WPF;assembly=HalconDotNet.WPF"
        Title="图像旋转" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="旋转角度:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="AngleTextBox" Width="100" Padding="5" Text="0"/>
            <TextBlock Text="度" VerticalAlignment="Center" Margin="5,0,0,0"/>
            <Button Content="应用" Click="ApplyButton_Click" Padding="15,5" Margin="20,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#3E3E42" BorderThickness="1">
            <halcon:HWindowControlWPF x:Name="HWindow" Background="Black"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>