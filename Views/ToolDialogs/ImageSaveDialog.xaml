<Window Base="{x:Type local:ToolDialogBase}" x:Class="VisionFlow.Views.ToolDialogs.ImageSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存图像" Height="280" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1A2634" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="💾 保存图像" Foreground="#E8F4FF" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <Border Grid.Row="1" Background="#243447" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="保存路径" Foreground="#8BA4C7" FontSize="10" Margin="0,0,0,4"/>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PathTextBox" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4"/>
                    <Button Grid.Column="1" Content="浏览..." Click="BrowseButton_Click" Background="#3D5A73" Foreground="White" BorderThickness="0" Padding="8,4" Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Text="格式" Foreground="#8BA4C7" FontSize="10" Margin="0,10,0,4"/>
                <ComboBox x:Name="FormatCombo" SelectedIndex="0" Background="#1A2634" Foreground="White" BorderBrush="#3D5A73" Padding="6,4">
                    <ComboBoxItem Content="PNG"/>
                    <ComboBoxItem Content="JPEG"/>
                    <ComboBoxItem Content="BMP"/>
                    <ComboBoxItem Content="TIFF"/>
                </ComboBox>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#0D6EFD" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
