<Window x:Class="VisionFlow.Views.ToolDialogs.ImageLoadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:VisionFlow.Views.ToolDialogs"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ha="http://schemas.mvtec.com/halcondotnet"
        Title="图像加载" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="FilePathTextBox" Width="500" Padding="5"/>
            <Button Content="浏览..." Click="BrowseButton_Click" Padding="10,5" Margin="10,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#3E3E42" BorderThickness="1">
            <ha:HWindowControlWPF x:Name="HWindow" Background="Black"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="80" Padding="5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Padding="5" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>