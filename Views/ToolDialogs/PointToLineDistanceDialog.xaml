<Window x:Class="VisionFlow.Views.ToolDialogs.PointToLineDistanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:VisionFlow.Views.ToolDialogs"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点线距离" Height="300" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="点线距离" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="点" Foreground="#AAA" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,3">
                <TextBlock Text="Row:" Foreground="#888" Width="40"/>
                <TextBox x:Name="PRTextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,3">
                <TextBlock Text="Col:" Foreground="#888" Width="40"/>
                <TextBox x:Name="PCTextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="直线" Foreground="#AAA" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,3">
                <TextBlock Text="Row1:" Foreground="#888" Width="40"/>
                <TextBox x:Name="LR1TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,3">
                <TextBlock Text="Col1:" Foreground="#888" Width="40"/>
                <TextBox x:Name="LC1TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                <TextBlock Text="Row2:" Foreground="#888" Width="40"/>
                <TextBox x:Name="LR2TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Col2:" Foreground="#888" Width="40"/>
                <TextBox x:Name="LC2TextBox" Text="0" Padding="3" Background="#3E3E42" Foreground="White" BorderBrush="#555" Width="80"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="距离:" Foreground="#AAA" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="DistanceTextBlock" Text="-" Foreground="#00D4FF" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="像素" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>

        <Button Grid.Row="4" Content="关闭" Click="CloseButton_Click" Width="80" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0" HorizontalAlignment="Right"/>
    </Grid>
</Window>