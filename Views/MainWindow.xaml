<Window x:Class="VisionFlow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VisionFlow.ViewModels;assembly=VisionFlow"
        xmlns:models="clr-namespace:VisionFlow.Models;assembly=VisionFlow"
        mc:Ignorable="d"
        Title="{Binding ProjectName, StringFormat='VisionFlow - {0}'}"
        Height="750" Width="1280"
        WindowStartupLocation="CenterScreen"
        MinWidth="960" MinHeight="620"
        Background="#0B1120">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep" Color="#0B1120"/>
        <SolidColorBrush x:Key="BgPanel" Color="#111827"/>
        <SolidColorBrush x:Key="BgCard" Color="#1F2937"/>
        <SolidColorBrush x:Key="BgHover" Color="#374151"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#06B6D4"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="Border" Color="#374151"/>

        <!-- 工具卡片样式 -->
        <Style x:Key="ToolCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 分类标题样式 -->
        <Style x:Key="CategoryHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RunCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" CommandParameter="{Binding SelectedNode}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧面板 ========== -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo区 -->
                <Border Grid.Row="0" Background="{StaticResource BgDeep}" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBlue}" Margin="0,0,10,0"/>
                            <TextBlock Text="VisionFlow" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="●" Foreground="{StaticResource AccentOrange}" FontSize="14" Margin="4,0,0,0"
                                       Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding ProjectName}" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 工程操作按钮 -->
                <Border Grid.Row="1" Padding="12,8" Background="#0F172A">
                    <UniformGrid Columns="3" Rows="1">
                        <Button Content="📂 打开" Command="{Binding OpenCommand}" Style="{StaticResource SecondaryBtn}" Margin="2"/>
                        <Button Content="💾 保存" Command="{Binding SaveCommand}" Style="{StaticResource SecondaryBtn}" Margin="2"/>
                        <Button Content="🆕 新建" Command="{Binding NewCommand}" Style="{StaticResource SecondaryBtn}" Margin="2"/>
                    </UniformGrid>
                </Border>

                <!-- 分类工具箱 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="10,8">
                    <ItemsControl ItemsSource="{Binding ToolCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,4">
                                    <!-- 分类标题 -->
                                    <Border CornerRadius="6" Padding="10,7" Cursor="Hand"
                                            MouseLeftButtonDown="CategoryHeader_Click" Tag="{Binding Key}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Key, Converter={StaticResource CategoryColorConverter}}"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Key, Converter={StaticResource CategoryNameConverter}}"
                                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Count, StringFormat='({0})'}"
                                                       Foreground="rgba(255,255,255,0.6)" FontSize="10"/>
                                        </Grid>
                                    </Border>

                                    <!-- 工具列表（可折叠）-->
                                    <ItemsControl ItemsSource="{Binding}" x:Name="ToolsItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ToolCard}"
                                                        MouseLeftButtonDown="ToolboxItem_MouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="34"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="28" Height="28" CornerRadius="6"
                                                                Background="#1F2937" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Icon}" FontSize="14"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                                       FontSize="12" FontWeight="Medium"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 分隔条 -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BgDeep}"/>

        <!-- ========== 右侧画布 ========== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶ 运行 (F5)" Command="{Binding RunCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                        <Button Content="⚙ 流程参数" Command="{Binding OpenParametersCommand}" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"/>
                        <Button Content="🗑 删除" Command="{Binding DeleteSelectedCommand}" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"/>
                        <Button Content="⚡ 压力测试" Click="StressTest_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- 节点数 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreen}" Margin="0,0,6,0"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">
                            <Run Text="{Binding Nodes.Count, Mode=OneWay}"/>
                            <Run Text="个节点"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 流程画布 -->
            <Border Grid.Row="1" Background="{StaticResource BgDeep}" ClipToBounds="True">
                <Canvas x:Name="FlowCanvas"
                        AllowDrop="True"
                        Drop="FlowCanvas_Drop"
                        DragOver="FlowCanvas_DragOver"
                        MouseLeftButtonDown="FlowCanvas_MouseLeftButtonDown"
                        MouseRightButtonDown="FlowCanvas_MouseRightButtonDown">
                    <!-- 网格背景 -->
                    <Canvas.Background>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="12,12" RadiusX="1" RadiusY="1"/>
                                    </GeometryDrawing.Geometry>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#1F2937"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Canvas.Background>
                </Canvas>
            </Border>
        </Grid>
    </Grid>
</Window>